    \includegraphics[width=0.85\textwidth]{render_front.jpeg}
    \caption{Concept render: tapered body shell with oak-veneer accent, recessed display, and iMRP500 chassis base. Generated during concept exploration and refined into engineering drawings.}
    \label{fig:render_front}
\end{figure}

\begin{figure}[H]
    \centering
    \includegraphics[width=0.85\textwidth]{engn_drawing_robot_dimensions.png}
    \caption{First-angle engineering drawing (23~Feb~2026) with critical dimensions: 900~mm height, 400~mm waist, 51.82° display tilt angle referenced from vertical, fabrication tolerances on all joining surfaces.}
    \label{fig:engn_drawing}
\end{figure}

\begin{figure}[H]
    \centering
